# AI模型配置示例
# 复制此文件为 .env 并填入您的配置

# ===========================================
# AI模型基础配置
# ===========================================

# 模型类型: zhipuai, openai, custom
AI_MODEL_TYPE=zhipuai

# API密钥 (必填)
AI_API_KEY=your_api_key_here

# API基础URL (可选，不同模型有默认值)
AI_BASE_URL=

# 模型ID (可选，不同模型有默认值)
AI_MODEL_ID=

# ===========================================
# 智谱AI配置示例
# ===========================================
# AI_MODEL_TYPE=zhipuai
# AI_API_KEY=your_zhipuai_api_key
# AI_MODEL_ID=glm-4

# ===========================================
# OpenAI配置示例
# ===========================================
# AI_MODEL_TYPE=openai
# AI_API_KEY=your_openai_api_key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL_ID=gpt-3.5-turbo

# ===========================================
# 自定义API配置示例 (如国内代理)
# ===========================================
# AI_MODEL_TYPE=custom
# AI_API_KEY=your_custom_api_key
# AI_BASE_URL=https://your-custom-api.com/v1
# AI_MODEL_ID=your-model-id

# ===========================================
# 其他应用配置
# ===========================================

# 智谱AI API密钥 (向后兼容)
ZHIPUAI_API_KEY=your_zhipuai_api_key

# 数据库配置
DATABASE_URL=sqlite:///app.db

# 缓存配置
REDIS_URL=redis://localhost:6379/0

# 应用配置
FLASK_ENV=development
SECRET_KEY=your_secret_key_here

# 主题聚类配置
CLUSTERING_METHOD=kmeans
CLUSTERING_NUM_TOPICS=5
CLUSTERING_MIN_SAMPLES=3
