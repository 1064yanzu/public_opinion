# AI模型配置示例
# 复制此文件为 .env 并填入您的配置

# ===========================================
# AI模型基础配置
# ===========================================

# 模型类型: zhipuai, openai, custom
AI_MODEL_TYPE=zhipuai

# 通用API密钥（必填）
AI_API_KEY=your_api_key_here

# 通用基地址（可选，openai/custom 需设置）
# 说明：
# - openai 模式建议填写 https://api.openai.com 或兼容网关地址（会自动补全 /v1）
# - custom 模式需填写完整地址，例如 https://your-custom-api.com/v1
AI_BASE_URL=

# 模型ID（可选，openai/custom 需设置）
# 说明：
# - zhipuai 默认 glm-4，可根据需要替换
# - openai 例如 gpt-3.5-turbo-0125 或 gpt-4o-mini 等
AI_MODEL_ID=

# 智谱AI配置示例
# AI_MODEL_TYPE=zhipuai
# AI_API_KEY=your_zhipuai_api_key
# AI_MODEL_ID=glm-4

# OpenAI配置示例（兼容模式）
# AI_MODEL_TYPE=openai
# AI_API_KEY=your_openai_api_key
# AI_BASE_URL=https://api.openai.com
# AI_MODEL_ID=gpt-3.5-turbo-0125

# 自定义兼容API示例
# AI_MODEL_TYPE=custom
# AI_API_KEY=your_custom_api_key
# AI_BASE_URL=https://your-custom-api.com/v1
# AI_MODEL_ID=your-model-id

# 可选：如果项目某些模块仍引用此变量
ZHIPUAI_API_KEY=your_zhipuai_api_key

# 数据库配置
DATABASE_URL=sqlite:///app.db

# 缓存配置
REDIS_URL=redis://localhost:6379/0

# 应用配置
FLASK_ENV=development
SECRET_KEY=your_secret_key_here

# 主题聚类配置
CLUSTERING_METHOD=kmeans
CLUSTERING_NUM_TOPICS=5
CLUSTERING_MIN_SAMPLES=3
