# 环境变量示例文件
# 复制此文件为.env并填入实际值

# Flask应用配置
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=production
FLASK_DEBUG=False

# SiliconFlow API配置
SILICONFLOW_API_KEY=your_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL_ID=ft:LoRA/Qwen/Qwen2.5-32B-Instruct:uy4pgkdhjs:yuqing:dkzxjcayvpokexfohjob

# AI助手访问密码
AI_ASSISTANT_PASSWORD=yuqing2024

# 智谱AI配置
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# 性能优化配置
CACHE_ENABLED=true
CACHE_TTL=3600
MAX_CACHE_SIZE=1000
BATCH_SIZE=100
MEMORY_LIMIT_MB=512

# 并发配置
MAX_WORKERS=4
MAX_CONCURRENT_REQUESTS=10
ENABLE_CONCURRENT_CRAWLING=true

# 网络配置
REQUEST_TIMEOUT=30
REQUEST_RETRY=3
REQUEST_DELAY=0.5

# 数据处理配置
ENABLE_DATA_PIPELINE=true
PIPELINE_PARALLEL=true

# 监控配置
MAX_METRICS=1000
CLEANUP_INTERVAL_HOURS=24
ENABLE_MONITORING=true

# 高级缓存配置（第三阶段新增）
L1_CACHE_SIZE=500
L1_CACHE_TTL=300
L2_CACHE_SIZE_MB=100
CACHE_DIR=cache

# 前端优化配置（第三阶段新增）
ENABLE_COMPRESSION=true
STATIC_CACHE_MAX_AGE=86400

# 告警配置（第三阶段新增）
EMAIL_ALERTS_ENABLED=false
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
ALERT_RECIPIENTS=admin@example.com,ops@example.com

# 数据预处理配置（第三阶段新增）
STOPWORDS_FILE=
TEXT_CLEANING_ENABLED=true
DATA_VALIDATION_ENABLED=true

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs
