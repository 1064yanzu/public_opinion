# 应用配置
APP_NAME=舆情分析系统
VERSION=2.0.0
DEBUG=True

# CORS 配置（开发环境）
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# 数据库配置
DATABASE_PATH=./public_opinion.db

# 安全配置（生产环境请务必修改！）
SECRET_KEY=your-very-secure-secret-key-please-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI 配置（如需使用 AI 功能）
AI_MODEL_TYPE=zhipuai
AI_API_KEY=
AI_BASE_URL=
AI_MODEL_ID=

# 性能配置
ENABLE_CACHE=True
CACHE_DURATION=300
MAX_WORKERS=4

# 爬虫配置
CRAWLER_MAX_PAGE=50
CRAWLER_TIMEOUT=30
CRAWLER_DELAY=1.0

# 监控配置
ENABLE_MONITORING=True
MONITORING_INTERVAL=60
